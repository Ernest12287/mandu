# =============================================================================
# Mandu Playground Runner — self-host environment file
# =============================================================================
# Copy this file to `.env` and fill in the values for your deployment:
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose up -d
#
# Caddy reads the PLAYGROUND_DOMAIN to pick an ACME certificate on first
# request. Make sure the DNS A/AAAA record for that domain points at this
# host BEFORE starting compose, or Let's Encrypt will fail challenges.
# =============================================================================

# The fully-qualified domain the playground will be served from.
# REQUIRED — Caddy uses this for TLS cert provisioning.
PLAYGROUND_DOMAIN=playground.example.com

# The allowed CORS origin for the playground front-end. Set to the site
# that *embeds* the playground component. Same-origin deployments can
# set it to `https://${PLAYGROUND_DOMAIN}` (this is the compose default
# if the value is empty).
PLAYGROUND_ORIGIN=https://example.com

# Email for Let's Encrypt renewal notices. Strongly recommended — LE
# emails you ~20 days before expiry if something blocks auto-renewal.
ACME_EMAIL=ops@example.com

# ---------------------------------------------------------------------------
# Optional overrides
# ---------------------------------------------------------------------------

# OCI image used for per-request ephemeral sandbox containers. The
# default matches the outer container so no extra pull is needed. For
# production you probably want a locally-built image that vendors
# @mandujs/core + react@19 at the version you've deployed (see
# Dockerfile.sandbox for the recipe).
# MANDU_DOCKER_SANDBOX_IMAGE=mandu-playground-sandbox:0.25.2

# GID of the host's `docker` group. Run `getent group docker | cut -d: -f3`
# to find it. Defaults to 999 which matches the Debian / Ubuntu standard.
# DOCKER_GID=999

# Turnstile secret for siteverify. Not wired into the self-host adapter
# today (the DockerSandboxAdapter does not call Cloudflare), but reserved
# so CF and self-host configurations stay parity. Safe to leave empty.
# TURNSTILE_SECRET=
