{
  "name": "mandujs",
  "version": "0.10.0",
  "private": true,
  "license": "MPL-2.0",
  "author": "Liam Ko",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "engines": {
    "bun": ">=1.3.12"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "demo/*"
    ],
    "catalog": {
      "fast-glob": "^3.3.2"
    }
  },
  "scripts": {
    "test": "bun test",
    "test:core": "bun run scripts/test-core.ts",
    "test:core:mysql-e2e": "bun run scripts/test-mysql-resource-e2e.ts",
    "test:cli": "bun test packages/cli/src packages/cli/tests packages/cli/templates/default/tests packages/cli/templates/realtime-chat/tests",
    "test:mcp": "bun test packages/mcp/tests",
    "test:ate": "bun test packages/ate/src packages/ate/tests packages/ate/__tests__",
    "test:edge": "bun test packages/edge/__tests__",
    "test:skills": "bun test packages/skills/src",
    "test:playground-runner": "bun test packages/playground-runner/tests",
    "test:demo": "bun run test:smoke",
    "test:smoke": "bun run ./scripts/smoke.ts",
    "test:packages": "bun run test:core && bun run test:cli && bun run test:mcp && bun run test:ate && bun run test:edge && bun run test:skills && bun run test:playground-runner",
    "perf:baseline:check": "bun run scripts/perf-baseline.ts",
    "perf:budget:check": "bun run scripts/perf-budget.ts",
    "perf:run": "bun run scripts/perf-run.ts",
    "perf:ci": "bun run perf:run -- --runs 1 --warmup 0 && bun run perf:budget:check -- --summary .perf/latest/summary.json --markdown-out .perf/latest/budget-check.md",
    "perf:expanded": "bun run perf:run -- --scenario auth-starter-hmr-island --runs 1 --warmup 0 && bun run perf:budget:check -- --summary .perf/latest/summary.json --markdown-out .perf/latest/budget-check.md",
    "perf:hydration": "bun run packages/core/benchmark/hydration-benchmark.ts",
    "mandu": "bun run packages/cli/src/main.ts",
    "changeset": "changeset",
    "version": "changeset version && bun install",
    "publish": "bun run scripts/publish.ts",
    "publish:dry": "bun run scripts/publish.ts --dry-run",
    "publish:force": "bun run scripts/publish.ts --skip-check",
    "release": "bun run version && bun run publish",
    "typecheck": "bun run scripts/typecheck.ts",
    "lint": "oxlint packages/",
    "lint:type-aware": "bun run scripts/lint-type-aware.ts",
    "lint:type-aware:debt": "oxlint --type-aware packages/core/src packages/cli/src packages/mcp/src packages/ate/src packages/edge/src packages/skills/src packages/playground-runner/src --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.ts\" --ignore-pattern \"**/*.test.tsx\"",
    "lint:type-aware:full": "oxlint --type-aware packages/",
    "lint:fix": "oxlint --fix packages/",
    "check:publish": "bun run scripts/pre-publish-check.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "bun-types": "^1.3.7",
    "lefthook": "^1.11.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "playwright": "^1.49.0",
    "typescript": ">=6.0.0"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-refresh": "^0.18.0",
    "zod": "^3.22.0"
  }
}
