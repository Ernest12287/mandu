{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@mandujs/core": ["packages/core/src/index.ts"],
      "@mandujs/core/*": ["packages/core/src/*"],
      "@mandujs/cli": ["packages/cli/src/main.ts"],
      "@mandujs/cli/*": ["packages/cli/src/*"],
      "@mandujs/mcp": ["packages/mcp/src/index.ts"],
      "@mandujs/mcp/*": ["packages/mcp/src/*"],
      "@mandujs/ate": ["packages/ate/src/index.ts"],
      "@mandujs/ate/*": ["packages/ate/src/*"],
      "@mandujs/skills": ["packages/skills/src/index.ts"],
      "@mandujs/skills/*": ["packages/skills/src/*.ts", "packages/skills/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["bun-types"]
  },
  "exclude": ["node_modules", "dist", "DNA", "demo"]
}
